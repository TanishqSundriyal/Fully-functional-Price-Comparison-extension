{
  "manifest_version": 3,
  "name": "PriceScope - Price Comparison Extension",
  "version": "1.0.0",
  "description": "Instantly compare product prices across the web and find the best deals.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
"action": {
    "default_popup": "popup/popup.html",
    "default_title": "PriceScope"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["popup/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
